# 替换 __PLACEHOLDER__ 为真实值

# ============ 流程组（bootstrap 时填） ============
id: __REQ_ID__                 # 例：REQ-2026-001
title: __TITLE__
phase: bootstrap
created_at: __CREATED_AT__     # 格式 YYYY-MM-DD HH:MM:SS（Asia/Shanghai），见 context/team/engineering-spec/time-format.md
branch: __BRANCH__             # 例：feat/req-2026-001
base_branch: __BASE_BRANCH__   # feat/* 派生的基点分支：develop / main / master
project: __PROJECT__           # 关联 context/project/<project>/
services: []                   # 涉及的服务仓库
gates_passed: []
pr_url: ""                     # /requirement:submit 成功后回写
pr_number: 0                   # /requirement:submit 成功后回写

# ============ 语义组（definition 阶段补齐，供跨需求检索） ============
feature_area: ""                         # definition 起必填；值必须在 context/project/<project>/areas.yaml 白名单内
change_type: ""                          # definition 起必填；枚举：feature / bugfix / refactor / perf / security
affected_modules: []                     # definition 起必填；自由词，建议与 services 子模块对齐
tags: []                                 # 可选；长尾标签，不归一化

# ============ 结果组（completed 时才填） ============
outcome: ""                    # shipped / abandoned / rolled-back
completed_at: ""               # ISO8601，completed 时填
lessons_extracted: false       # /knowledge:extract-experience 是否已跑
