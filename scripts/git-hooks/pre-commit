#!/usr/bin/env bash
# 本地 pre-commit 校验 —— 统一门禁 runner（F-002 改写）
#
# 启用方式（项目级，一次性）：
#   git config core.hooksPath scripts/git-hooks
#
# 策略：
#   - 切到 python3 scripts/gates/run.py --trigger=pre-commit
#   - runner 内部按各 plugin 的 precheck 决定是否真跑（避免无关 commit 耗时）
#   - 只拦 error，不拦 warning（--strict 不加，warning 由人工治理）
#   - 绕过：`git commit --no-verify`（紧急 hotfix 时允许，但 CI 兜底）
#
# 注意：reviews/*.json / meta.yaml.reviews 段的保护由 GATE-PROTECT-BRANCH
#       在 pre-tool-use trigger 处理；pre-commit hook 不重复实现。

set -uo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "${REPO_ROOT}"

# 取本次 staged 的文件列表（用于传给 runner 做 precheck 过滤）
STAGED="$(git diff --cached --name-only --diff-filter=ACMR)"
if [ -z "${STAGED}" ]; then
    exit 0
fi

# 把 staged 文件列表传给 runner 做 changed_files 过滤（runner 通过 stdin 接收）
# 当前版本 run.py 的 build_context 不直接读 stdin，changed_files 由 filter_gates 处理；
# 此处把 staged 列表透传给 runner 的 extra.changed_files 通过环境变量。
export GATE_CHANGED_FILES="${STAGED}"

# 执行统一门禁 runner（pre-commit trigger，不加 --strict，只拦 error）
# 注意：关闭 set -e 以捕获 runner 的非零退出码（让友好提示生效，不被 set -e 截断）
set +e
python3 scripts/gates/run.py --trigger=pre-commit
EXIT_CODE=$?
set -e

if [ $EXIT_CODE -ne 0 ]; then
    echo "" >&2
    echo "✗ pre-commit 门禁失败，commit 被阻止" >&2
    echo "  修复后重新 git add && git commit" >&2
    echo "  紧急情况可用 \`git commit --no-verify\`，但 CI 仍会拦" >&2
fi

exit $EXIT_CODE
