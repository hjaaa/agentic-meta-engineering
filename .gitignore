# 个人 Claude Code 配置覆盖（不入库）
.claude/settings.local.json

# 项目级 MCP 实际配置（从 .mcp.json.example 复制生成，个人按需裁剪）
.mcp.json

# 代码审查运行态临时文件（每次 /code-review 会重写）
.review-scope.json

# macOS
.DS_Store

# 编辑器
.idea/
.vscode/
*.swp

# Python 字节码缓存（scripts/lib 里的 .py 被执行时生成）
__pycache__/
*.pyc

# 需求运行态：工具级日志（auto-progress-log Hook 写入，高频噪音）
# 语义事件仍在 process.txt，入 git；此处仅排除工具日志
requirements/**/process.tool.log
